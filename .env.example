# Database Connection
# SQLite (recommended for low-memory environments like Raspberry Pi)
DATABASE_URL=file:../data/dev.db

# PostgreSQL (uncomment below and comment SQLite if using PostgreSQL)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/diecast360

# JWT Configuration
JWT_SECRET=super-secret-jwt-key
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_EXPIRES_IN=7d

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10
ALLOWED_MIME=image/jpeg,image/png,image/webp

# Server Configuration
PORT=3000

# Public URL
# Used for CORS in backend and generation of links
FRONTEND_URL=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:5173

# Frontend Configuration
# Used during build time for frontend
VITE_API_URL=http://localhost:3000/api/v1

# Cookie Security Settings
# IMPORTANT: Change COOKIE_SECRET in production!
COOKIE_SECRET=change-me-to-random-32-char-string
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# AI Configuration (Optional but recommended)
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Vector Database (Pinecone) - Optional for search
# Get key from: https://app.pinecone.io/
PINECONE_API_KEY=
PINECONE_INDEX=diecast360
