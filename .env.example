# Database Connection
# SQLite (recommended for low-memory environments like Raspberry Pi)
DATABASE_URL=file:./dev.db

# PostgreSQL (uncomment below and comment SQLite if using PostgreSQL)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/diecast360

# JWT Configuration
JWT_SECRET=change-me
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10
ALLOWED_MIME=image/jpeg,image/png

# Public URL
PUBLIC_BASE_URL=http://localhost:5173
