// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ItemStatus {
  con_hang
  giu_cho
  da_ban
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password_hash String
  full_name     String?
  role          String    @default("admin")
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  
  refresh_tokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id         String    @id @default(uuid())
  user_id    String
  token_hash String    @unique
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime  @default(now())
  
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
  @@index([user_id])
}

model Item {
  id             String      @id @default(uuid())
  name           String
  description    String?
  scale          String      @default("1:64")
  brand          String?
  car_brand      String?
  model_brand    String?
  condition      String?
  price          Decimal?
  original_price Decimal?
  status         ItemStatus  @default(con_hang)
  is_public      Boolean     @default(false)
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  deleted_at     DateTime?
  notes          String?
  fb_post_content String?
  
  item_images    ItemImage[]
  spin_sets      SpinSet[]
  facebook_posts FacebookPost[]

  @@map("items")
  @@index([status])
  @@index([created_at])
  @@index([deleted_at])
  @@index([car_brand])
  @@index([model_brand])
  @@index([condition])
}

model FacebookPost {
  id         String   @id @default(uuid())
  item_id    String
  post_url   String
  content    String?
  posted_at  DateTime @default(now())
  created_at DateTime @default(now())

  item Item @relation(fields: [item_id], references: [id], onDelete: Cascade)

  @@map("facebook_posts")
  @@index([item_id])
}

model ItemImage {
  id             String   @id @default(uuid())
  item_id        String
  file_path      String
  thumbnail_path String?
  is_cover       Boolean  @default(false)
  display_order  Int      @default(0)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  
  item Item @relation(fields: [item_id], references: [id], onDelete: Cascade)

  @@map("item_images")
  @@index([item_id, display_order])
}

model SpinSet {
  id         String       @id @default(uuid())
  item_id    String
  label      String?
  is_default Boolean      @default(false)
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt
  
  item    Item         @relation(fields: [item_id], references: [id], onDelete: Cascade)
  frames  SpinFrame[]

  @@map("spin_sets")
  @@index([item_id])
  @@index([item_id, is_default])
}

model SpinFrame {
  id             String   @id @default(uuid())
  spin_set_id    String
  frame_index    Int
  file_path      String
  thumbnail_path String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  
  spin_set SpinSet @relation(fields: [spin_set_id], references: [id], onDelete: Cascade)

  @@map("spin_frames")
  @@unique([spin_set_id, frame_index])
  @@index([spin_set_id, frame_index])
}

model Category {
  id            String   @id @default(uuid())
  name          String
  type          String   // "car_brand" | "model_brand"
  is_active     Boolean  @default(true)
  display_order Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("categories")
  @@unique([type, name])
  @@index([type, is_active])
  @@index([type, display_order])
}

model AiItemDraft {
  id              String   @id @default(uuid())
  images_json     String   // JSON string of image paths
  extracted_text  String?
  ai_json         String   // JSON string of structured item data
  confidence_json String?  // JSON string of confidence scores
  status          String   @default("PENDING") // PENDING, CONFIRMED, REJECTED
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("ai_item_drafts")
}
