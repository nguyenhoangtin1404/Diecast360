// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

enum ItemStatus {
  con_hang
  giu_cho
  da_ban
}

enum PlatformRole {
  platform_super
}

enum ShopRole {
  super_admin
  shop_admin
  shop_staff
}

enum ShopAuditAction {
  add_shop_admin
  reset_member_password
  set_member_active
  update_shop
  deactivate_shop
  activate_shop
  set_platform_role
  set_shop_member_role
}

enum PreOrderStatus {
  PENDING_CONFIRMATION @map("cho_xac_nhan")
  WAITING_FOR_GOODS    @map("dang_cho_hang")
  ARRIVED              @map("da_ve")
  PAID                 @map("da_thanh_toan")
  CANCELLED            @map("da_huy")
}

enum InventoryTransactionType {
  stock_in
  stock_out
  adjustment
}

enum MemberPointsMutationType {
  earn
  redeem
  adjust
}

model Shop {
  id         String         @id @default(uuid())
  name       String
  slug       String         @unique
  is_active  Boolean        @default(true)
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt

  items      Item[]
  pre_orders PreOrder[]
  user_roles UserShopRole[]
  audit_logs ShopAuditLog[]
  inventory_transactions InventoryTransaction[]
  members    Member[]
  membership_tiers MembershipTier[]
  member_points_ledger MemberPointsLedger[]

  @@map("shops")
  @@index([is_active])
}

model UserShopRole {
  user_id    String
  shop_id    String
  role       ShopRole @default(shop_admin)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  shop Shop @relation(fields: [shop_id], references: [id], onDelete: Cascade)

  @@id([user_id, shop_id])
  @@map("user_shop_roles")
  @@index([user_id])
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password_hash String
  full_name     String?
  role          String         @default("admin")
  platform_role PlatformRole?
  is_active     Boolean        @default(true)
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt

  refresh_tokens RefreshToken[]
  shop_roles     UserShopRole[]
  audit_logs     ShopAuditLog[] @relation("ShopAuditActor")
  pre_orders     PreOrder[]
  inventory_transactions InventoryTransaction[]
  member_points_ledger MemberPointsLedger[]

  @@map("users")
}

model ShopAuditLog {
  id            String          @id @default(uuid())
  shop_id       String
  actor_user_id String?
  action        ShopAuditAction
  target_type   String
  target_id     String?
  metadata_json String?
  created_at    DateTime        @default(now())

  shop  Shop  @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  actor User? @relation("ShopAuditActor", fields: [actor_user_id], references: [id], onDelete: SetNull)

  @@map("shop_audit_logs")
  @@index([shop_id, created_at])
  @@index([action, created_at])
}

model RefreshToken {
  id         String    @id @default(uuid())
  user_id    String
  token_hash String    @unique
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime  @default(now())
  
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
  @@index([user_id])
}

model Item {
  id             String      @id @default(uuid())
  name           String
  description    String?
  scale          String      @default("1:64")
  brand          String?
  car_brand      String?
  model_brand    String?
  condition      String?
  price          Decimal?
  original_price Decimal?
  status         ItemStatus  @default(con_hang)
  quantity       Int         @default(1)
  attributes     Json        @default("{}")
  is_public      Boolean     @default(false)
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  deleted_at     DateTime?
  notes          String?
  fb_post_content String?
  // Multi-tenant: shop_id is nullable for backward-compatible migration.
  // All new items must have a shop_id. Migration sets existing items to default shop.
  shop_id        String?

  item_images    ItemImage[]
  spin_sets      SpinSet[]
  facebook_posts FacebookPost[]
  vector_sync_task VectorSyncTask?
  pre_orders     PreOrder[]
  inventory_transactions InventoryTransaction[]
  shop           Shop?       @relation(fields: [shop_id], references: [id])

  @@map("items")
  @@index([status])
  @@index([created_at])
  @@index([deleted_at])
  @@index([car_brand])
  @@index([model_brand])
  @@index([condition])
  @@index([shop_id])
}

model InventoryTransaction {
  id                String                   @id @default(uuid())
  shop_id           String
  item_id           String
  actor_user_id     String?
  reversal_of_id    String?                  @unique
  type              InventoryTransactionType
  quantity          Int
  delta             Int
  resulting_quantity Int
  reason            String
  note              String?
  created_at        DateTime                 @default(now())

  shop  Shop  @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  item  Item  @relation(fields: [item_id], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actor_user_id], references: [id], onDelete: SetNull)
  reversal_of InventoryTransaction? @relation("InventoryTransactionReversal", fields: [reversal_of_id], references: [id], onDelete: SetNull)
  reversed_by InventoryTransaction? @relation("InventoryTransactionReversal")

  @@map("inventory_transactions")
  @@index([shop_id, created_at])
  @@index([item_id, created_at])
  @@index([item_id, type, created_at])
}

model PreOrder {
  id                   String         @id @default(uuid())
  shop_id              String
  item_id              String
  user_id              String?
  status               PreOrderStatus @default(PENDING_CONFIRMATION)
  quantity             Int            @default(1)
  unit_price           Decimal?
  total_amount         Decimal?
  deposit_amount       Decimal        @default(0)
  paid_amount          Decimal        @default(0)
  expected_arrival_at  DateTime?
  expected_delivery_at DateTime?
  note                 String?
  cover_image_url      String?
  created_at           DateTime       @default(now())
  updated_at           DateTime       @updatedAt
  cancelled_at         DateTime?
  completed_at         DateTime?

  shop Shop  @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  item Item  @relation(fields: [item_id], references: [id], onDelete: Restrict)
  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@map("pre_orders")
  @@index([shop_id, status])
  @@index([item_id])
  @@index([user_id])
  @@index([shop_id, expected_arrival_at])
}

model MembershipTier {
  id         String   @id @default(uuid())
  shop_id    String
  name       String
  rank       Int
  min_points Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  shop    Shop     @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  members Member[]

  @@map("membership_tiers")
  @@index([shop_id, rank])
  @@unique([shop_id, name])
  @@unique([shop_id, rank])
}

model Member {
  id             String   @id @default(uuid())
  shop_id        String
  full_name      String
  email          String?
  phone          String?
  points_balance Int      @default(0)
  tier_id        String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  shop   Shop            @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  tier   MembershipTier? @relation(fields: [tier_id], references: [id], onDelete: SetNull)
  points MemberPointsLedger[]

  @@map("members")
  @@index([shop_id, created_at])
  @@index([shop_id, points_balance])
  @@index([shop_id, full_name])
  @@unique([shop_id, email])
  @@unique([shop_id, phone])
}

model MemberPointsLedger {
  id            String                   @id @default(uuid())
  member_id     String
  shop_id       String
  actor_user_id String?
  type          MemberPointsMutationType
  points        Int
  delta         Int
  balance_after Int
  reason        String
  note          String?
  created_at    DateTime                 @default(now())

  member Member @relation(fields: [member_id], references: [id], onDelete: Cascade)
  shop   Shop   @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  actor  User?  @relation(fields: [actor_user_id], references: [id], onDelete: SetNull)

  @@map("member_points_ledger")
  @@index([member_id, created_at])
  @@index([shop_id, created_at])
  @@index([shop_id, type, created_at])
}

model FacebookPost {
  id         String   @id @default(uuid())
  item_id    String
  post_url   String
  content    String?
  posted_at  DateTime @default(now())
  created_at DateTime @default(now())

  item Item @relation(fields: [item_id], references: [id], onDelete: Cascade)

  @@map("facebook_posts")
  @@index([item_id])
}

model ItemImage {
  id             String   @id @default(uuid())
  item_id        String
  file_path      String
  thumbnail_path String?
  is_cover       Boolean  @default(false)
  display_order  Int      @default(0)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  
  item Item @relation(fields: [item_id], references: [id], onDelete: Cascade)

  @@map("item_images")
  @@index([item_id, display_order])
}

model SpinSet {
  id         String       @id @default(uuid())
  item_id    String
  label      String?
  is_default Boolean      @default(false)
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt
  
  item    Item         @relation(fields: [item_id], references: [id], onDelete: Cascade)
  frames  SpinFrame[]

  @@map("spin_sets")
  @@index([item_id])
  @@index([item_id, is_default])
}

model SpinFrame {
  id             String   @id @default(uuid())
  spin_set_id    String
  frame_index    Int
  file_path      String
  thumbnail_path String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  
  spin_set SpinSet @relation(fields: [spin_set_id], references: [id], onDelete: Cascade)

  @@map("spin_frames")
  @@unique([spin_set_id, frame_index])
  @@index([spin_set_id, frame_index])
}

model Category {
  id            String   @id @default(uuid())
  name          String
  type          String   // "car_brand" | "model_brand"
  is_active     Boolean  @default(true)
  display_order Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("categories")
  @@unique([type, name])
  @@index([type, is_active])
  @@index([type, display_order])
}

model AiItemDraft {
  id              String   @id @default(uuid())
  images_json     String   // JSON string of image paths
  extracted_text  String?
  ai_json         String   // JSON string of structured item data
  confidence_json String?  // JSON string of confidence scores
  status          String   @default("PENDING") // PENDING, CONFIRMED, REJECTED
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("ai_item_drafts")
}

model VectorSyncTask {
  item_id       String   @id
  attempt_count Int      @default(0)
  last_error    String?
  scheduled_at  DateTime @default(now())
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  item Item @relation(fields: [item_id], references: [id], onDelete: Cascade)

  @@map("vector_sync_tasks")
  @@index([scheduled_at])
}
